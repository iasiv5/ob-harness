# === ob 入口: sourced lib 分区(OB_ENTRY_DIR 须在 source lib 前算好) ===
OB_ENTRY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
for f in "$OB_ENTRY_DIR"/lib/*.sh; do
