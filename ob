for f in "$OB_ENTRY_DIR"/lib/*.sh; do
    # shellcheck disable=SC1090
    source "$f"
done
# === 入口 (parse_args / usage / main) ===

parse_args() {
    if [[ $# -lt 1 ]]; then
        COMMAND=""
        return 0
    fi

    # Handle global --help/-h before dispatching to subcommands
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        usage
        exit 0
    fi

    COMMAND="$1"
    shift

    case "$COMMAND" in
        init)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        status)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        build)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        start-qemu)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        stop-qemu)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        *)
            error "Unknown command: $COMMAND"
            usage
            exit 1
            ;;
    esac

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|-D|--dry-run)    DRY_RUN=1; shift ;;
            -s|-S|--skip-deps)   SKIP_DEPS=1; shift ;;
            -u|-U|--url)
                if [[ $# -lt 2 ]]; then
                    error "Missing value for --url"
                    usage
                    exit 1
                fi
                OPENBMC_REPO_URL="$2"
                shift 2
                ;;
            -v|-V|--verbose)  VERBOSE=1; shift ;;
            -h|-H|--help)     usage; exit 0 ;;
            --ssh-port)
                if [[ $# -lt 2 ]]; then error "Missing value for --ssh-port"; exit 1; fi
                QEMU_SSH_PORT="$2"; shift 2 ;;
            --redfish-port)
                if [[ $# -lt 2 ]]; then error "Missing value for --redfish-port"; exit 1; fi
                QEMU_REDFISH_PORT="$2"; shift 2 ;;
            --ipmi-port)
                if [[ $# -lt 2 ]]; then error "Missing value for --ipmi-port"; exit 1; fi
                QEMU_IPMI_PORT="$2"; shift 2 ;;
            --http-port)
                if [[ $# -lt 2 ]]; then error "Missing value for --http-port"; exit 1; fi
                QEMU_HTTP_PORT="$2"; shift 2 ;;
            --serial-log)
                if [[ $# -lt 2 ]]; then error "Missing value for --serial-log"; exit 1; fi
                QEMU_SERIAL_LOG="$2"; shift 2 ;;
            --no-wait)  QEMU_NO_WAIT=1; shift ;;
            --force)    QEMU_FORCE=1; shift ;;
            --all)      QEMU_STOP_ALL=1; shift ;;
            *)             error "Unknown option: $1"; usage; exit 1 ;;
        esac
    done
}

usage() {
    cat <<EOF
Usage: ob [command] [options] [arguments]

Run without arguments to enter interactive menu mode.

Commands:
  init         [<machine>]    One-click initialize OpenBMC dev environment
  build        [<machine>]    Build an initialized machine's image (interactive if omitted)
  status                      Show current OpenBMC source binding status
  start-qemu   [<machine>]    Launch QEMU with built BMC image
  stop-qemu    [<machine>]    Stop a running QEMU instance

Global Options:
  -d, --dry-run         Print actions without executing
  -s, --skip-deps       Reuse existing deps.json, skip dependency resolution (init only)
  -u, --url <url>       Use a custom OpenBMC repository URL (init only)
  -v, --verbose         Verbose output
  -h, --help            Show this help

start-qemu Options:
  --ssh-port <port>       SSH port forwarding    (default: 2222)
  --redfish-port <port>   Redfish port forwarding (default: 2443)
  --ipmi-port <port>      IPMI port forwarding    (default: 2623, UDP)
  --http-port <port>      HTTP port forwarding    (no default; set to enable)
  --serial-log <path>     Serial log file path    (default: ~/tmp/qemu-<machine>-serial.log)
  --no-wait               Don't wait for BMC to become ready
  --force                 Kill existing instance without confirmation

stop-qemu Options:
  --force                 Stop without confirmation
  --all                   Stop all running QEMU instances

Exit Codes:
  0   Success (or benign no-op)
  1   Failure — broken, or usage error (e.g. unknown option)
  2   Cancelled by user (not a failure)
  3   Precondition missing (e.g. machine not initialized / not built);
      satisfy it via ob (run the suggested 'ob ...' first), then retry

Environment Variables (lower priority than command-line options):
  OB_OPENBMC_URL          Custom OpenBMC repository URL (init, non-interactive mode)
  OB_QEMU_SSH_PORT        SSH port override
  OB_QEMU_REDFISH_PORT    Redfish port override
  OB_QEMU_IPMI_PORT       IPMI port override
  OB_QEMU_HTTP_PORT       HTTP port override
  OB_QEMU_SERIAL_LOG      Serial log path override
  OB_QEMU_BINARY_URL      Custom QEMU binary download URL
  OB_NPM_REGISTRY         Override npm registry URL (set empty to disable auto-detection)

Examples:
  ob init                          # List machines and choose interactively
  ob init romulus                  # Initialize romulus machine
  ob init romulus -d               # Preview what would be done
  ob init romulus --url https://example.com/openbmc.git
  ob build romulus                 # Build romulus non-interactively
  ob build romulus -d              # Preview the build without running bitbake
  ob start-qemu romulus            # Launch romulus in QEMU
  ob start-qemu romulus --ssh-port 22223
  ob stop-qemu romulus             # Stop romulus QEMU instance
  ob stop-qemu --all               # Stop all running instances
EOF
}

main() {
    SECONDS=0
    parse_args "$@"
    detect_harness_root

    if [[ -z "$COMMAND" ]]; then
        cmd_menu
        return $?
    fi

    # CLI mode
    show_logo

    if [[ "$COMMAND" == "status" ]]; then
        cmd_status
        return $?
    fi

    if [[ "$COMMAND" == "build" ]]; then
        cmd_build
        return $?
    fi

    if [[ "$COMMAND" == "start-qemu" ]]; then
        cmd_start_qemu
        return $?
    fi

    if [[ "$COMMAND" == "stop-qemu" ]]; then
        cmd_stop_qemu
        return $?
    fi

    cmd_init
}

if [[ -z "${OB_NO_MAIN:-}" ]]; then
    main "$@"
fi
