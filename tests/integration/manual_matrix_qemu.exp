#!/usr/bin/env expect
#
# 手动矩阵 QEMU 段 —— 覆盖需运行中 QEMU 实例的交互分支。自包含启停。
#
# 【什么时候用】
#   - 改了 start-qemu / stop-qemu 的实例检测、kill-restart 确认、停止清理逻辑后
#   - 想验证“已有同名实例 → 拒绝 kill-restart”和“正常停止 + 清理”两条路径
#   - 注意：会真实启动 QEMU（占端口），不要在共用机器上随便跑
#
# 【怎么用】
#   前提：expect + workspace 里有 init+build 过的 machine（默认 romulus）。
#   $ expect tests/manual_matrix_qemu.exp
#   $ QEMU_MACHINE=romulus expect tests/manual_matrix_qemu.exp   # 换 machine
#   副作用：临时启动 QEMU（占端口），末尾正常停止清理；中途失败则 --force 兜底。
#   退出：FAIL=0 → exit 0；FAIL>0 → exit 1（失败时已 --force 清理）。
#
# 【覆盖项】（退出码协议：0=成功 / 2=用户取消）
#   start-qemu --no-wait 启动(0)          [前置：起一个 QEMU 供后续检测]
#   start-qemu kill-restart 拒绝(2)        [已有同名实例 → "Kill and restart? [y/N]" → n]
#   stop-qemu 选实例取消(2)                [列实例 → "0 to cancel" → 0]
#   stop-qemu 正常停止(0)                  [选实例 → "Stop this instance? [y/N]" → Y，兼清理]
#
# 【原理/注意】
#   - 自包含：脚本自己起 QEMU（--no-wait 跳过 BMC 等待），测完自己停掉清理。
#   - 启动 + kill-restart 检测各需一次 bitbake -e，较慢（timeout 300）。
#   - 交互用内联 spawn + while/简单 expect（proc 包装的 split/eval 在 expect 里
#     spawn_id 不可靠，已实测）。
#
# 【由来】与 manual_matrix.exp 配对：后者不需 QEMU，本段补需运行中实例的 4 条路径。

if {[info exists env(QEMU_MACHINE)]} { set MACHINE $env(QEMU_MACHINE) } else { set MACHINE "romulus" }
set timeout 300
log_user 0
set PASS 0; set FAIL 0

proc chk {label got exp} {
    global PASS FAIL
    if {$got == $exp} { incr PASS; puts "ok   $label => exit $got" } else { incr FAIL; puts "FAIL $label => exit $got (expected $exp)" }
}

# === 前置：启动 QEMU（confirm Y，--no-wait 跳过 BMC 等待；while 循环等 eof）===
puts "启动 QEMU $MACHINE ..."
spawn ./ob start-qemu $MACHINE --no-wait
set go 1; set conf 0
while {$go} {
    expect {
        -re "0 to cancel" { send "1\r" }
        -re "Type.*to confirm" { if {!$conf} { send "Y\r"; set conf 1 } }
        eof { set go 0 }
        timeout { set go 0; puts "FAIL 启动 QEMU 超时（bitbake -e 太慢，调大 timeout）" }
    }
}
catch wait r
set start_rc [lindex $r 3]
chk "start-qemu $MACHINE --no-wait" $start_rc 0
if {$start_rc != 0} {
    puts "启动失败，中止（无运行中 QEMU 可测）"
    catch {exec ./ob stop-qemu $MACHINE --force >/dev/null 2>&1}
    puts "\nPASS=$PASS FAIL=$FAIL"; exit 1
}

# === T11: 已有实例 → kill-restart 拒绝（需再过一次 bitbake -e 到实例检测）===
spawn ./ob start-qemu $MACHINE
expect -re "Kill and restart"; send "n\r"
expect eof; catch wait r
chk "kill-restart 拒绝" [lindex $r 3] 2

# === T12: stop 选实例取消 ===
spawn ./ob stop-qemu
expect -re "0 to cancel"; send "0\r"
expect eof; catch wait r
chk "stop 选实例取消" [lindex $r 3] 2

# === T13: stop 正常停止（兼清理）===
spawn ./ob stop-qemu
expect -re "0 to cancel"; send "1\r"
expect -re "Stop this instance"; send "Y\r"
expect eof; catch wait r
chk "stop 正常停止（清理）" [lindex $r 3] 0

puts "\nPASS=$PASS FAIL=$FAIL"
if {$FAIL > 0} {
    catch {exec ./ob stop-qemu $MACHINE --force >/dev/null 2>&1}
    puts "(已 --force 兜底清理 $MACHINE)"
}
exit [expr {$FAIL > 0 ? 1 : 0}]
